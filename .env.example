# Renderer backend: mock, auto, sdxl_mps, or flux2_klein.
RENDER_BACKEND=mock

# Runtime target for model backends. Use auto unless you need to force cuda, mps, or cpu.
DEVICE=auto

# Optional local model overrides for flux2_klein. Use paths on your own machine.
# CUDA uses the Flux2 FP8 Qwen encoder by default. MPS/CPU use Qwen/Qwen3-4B.
# KLEIN_4B_MODEL_PATH=/absolute/path/to/flux-2-klein-4b.safetensors
# FLUX2_TEXT_ENCODER_MODEL=/absolute/path/to/qwen3-transformers-model
# Set AE_MODEL_PATH only for a BFL-compatible AE state dict.
# AE_MODEL_PATH=/absolute/path/to/bfl-compatible-ae.safetensors
